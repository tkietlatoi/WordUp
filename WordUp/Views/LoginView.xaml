<UserControl x:Class="WordUp.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WordUp">
    <Grid Margin="18,16,18,20">
        <Border Style="{StaticResource Card}"
                Width="360"
                MaxWidth="360"
                VerticalAlignment="Center"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="74" Height="74" CornerRadius="14" Background="#F0EEFA" HorizontalAlignment="Center" Margin="0,4,0,14">
                        <TextBlock Text="WU" FontSize="24" FontWeight="Bold" Foreground="{StaticResource IndigoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="WordUp" Style="{StaticResource PageTitleText}" TextAlignment="Center" />
                    <TextBlock Text="N&#7873;n t&#7843;ng h&#7885;c t&#7915; v&#7921;ng chuy&#234;n nghi&#7879;p" Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,4,0,24" />

                    <Grid Width="220" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="4" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <Button Content="&#272;&#259;ng nh&#7853;p"
                                Style="{StaticResource ActiveAuthTabButton}" />
                        <Button Grid.Column="1"
                                Content="&#272;&#259;ng k&#253;"
                                Style="{StaticResource AuthTabButton}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Register" />
                        <Border Grid.Row="1"
                                Width="54"
                                Height="3"
                                Background="{StaticResource IndigoBrush}"
                                CornerRadius="2"
                                HorizontalAlignment="Center" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Email ho&#7863;c s&#7889; &#273;i&#7879;n tho&#7841;i" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource TextInput}" Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="M&#7853;t kh&#7849;u" VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Qu&#234;n m&#7853;t kh&#7849;u?"
                                Style="{StaticResource TextLinkButton}"
                                HorizontalAlignment="Right"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="ForgotPassword" />
                    </Grid>
                    <PasswordBox Style="{StaticResource PasswordInput}" local:PasswordBoxHelper.BoundPassword="{Binding LoginPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                    <TextBlock Text="{Binding AuthMessage}" FontSize="12" Margin="0,0,0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAuthMessageSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Content="Ti&#7871;p t&#7909;c" Style="{StaticResource PrimaryButton}" Command="{Binding LoginCommand}" />
                    <Button Content="Quay v&#7873; Trang ch&#7911;" Style="{StaticResource TextLinkButton}" HorizontalAlignment="Center" Margin="0,16,0,0" Command="{Binding SelectTabCommand}" CommandParameter="Dashboard" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
