<UserControl x:Class="WordUp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="AvatarButton" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="{StaticResource IndigoBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="24"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TodayIconButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="18"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F0EEFA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="22,18,22,22">
        <Grid>
            <StackPanel Margin="0,0,104,0">
                <TextBlock Text="{Binding DashboardGreeting}" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="{Binding DashboardSubtitle}" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
            </StackPanel>
            <Button Content="{Binding User.Initials}" Style="{StaticResource AvatarButton}" HorizontalAlignment="Right" Command="{Binding NavigateCommand}" CommandParameter="Account" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}" />
            <Button Content="Đăng nhập" Style="{StaticResource PrimaryButton}" Width="92" Height="38" HorizontalAlignment="Right" Command="{Binding NavigateCommand}" CommandParameter="Login" Visibility="{Binding IsGuest, Converter={StaticResource BoolToVisibility}}" />
        </Grid>

        <Border Style="{StaticResource Card}" Margin="0,24,0,14" Visibility="{Binding IsGuest, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="Welcome" FontSize="26" FontWeight="Bold" TextAlignment="Center" Foreground="{StaticResource IndigoBrush}" />
                <TextBlock Text="Bắt đầu học từ vựng, ôn tập và theo dõi tiến độ của bạn tại WordUp." Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,12,0,20" />
                <Button Content="Đăng nhập để học ngay" Style="{StaticResource PrimaryButton}" Command="{Binding NavigateCommand}" CommandParameter="Login" />
                <Button Content="Tạo tài khoản mới" Style="{StaticResource OutlineButton}" Margin="0,10,0,0" Command="{Binding NavigateCommand}" CommandParameter="Register" />
            </StackPanel>
        </Border>

        <TextBlock Text="Tổng quan" Style="{StaticResource SectionTitleText}" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}" />
        <UniformGrid Columns="2" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource Card}" Margin="0,0,8,14">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding StudyStreakDays}" FontSize="28" FontWeight="Bold" TextAlignment="Center" Foreground="{StaticResource IndigoBrush}" />
                    <TextBlock Text="Chuỗi" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock Text="ngày đã học liên tiếp" Style="{StaticResource MutedText}" TextAlignment="Center" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,0,14">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TotalLessons}" FontSize="28" FontWeight="Bold" TextAlignment="Center" Foreground="{StaticResource IndigoBrush}" />
                    <TextBlock Text="Bài học" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock Text="tổng bài trong hệ thống" Style="{StaticResource MutedText}" TextAlignment="Center" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="0,0,8,14">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TotalVocabularyWords}" FontSize="28" FontWeight="Bold" TextAlignment="Center" Foreground="{StaticResource IndigoBrush}" />
                    <TextBlock Text="Từ vựng" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock Text="tổng số từ hiện có" Style="{StaticResource MutedText}" TextAlignment="Center" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,0,14">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding LearnedOrRememberedWords}" FontSize="28" FontWeight="Bold" TextAlignment="Center" Foreground="{StaticResource IndigoBrush}" />
                    <TextBlock Text="Đã học/nhớ" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock Text="từ đã học hoặc ghi nhớ" Style="{StaticResource MutedText}" TextAlignment="Center" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <TextBlock Text="Tiếp tục học" Style="{StaticResource SectionTitleText}" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}" />
        <Border Style="{StaticResource Card}" Padding="16" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="{Binding ContinueLearningDeck.Name}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ContinueLearningProgress}" Style="{StaticResource MutedText}" Margin="0,5,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="Bấm tiếp tục để quay lại bài học gần đây nhất." Style="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Content="Tiếp tục" Style="{StaticResource PrimaryButton}" Width="96" Height="38" HorizontalAlignment="Right" Command="{Binding StartLessonCommand}" CommandParameter="{Binding ContinueLearningDeck}" />
            </Grid>
        </Border>

        <TextBlock Text="Bài học gần đây" Style="{StaticResource SectionTitleText}" />
        <ItemsControl ItemsSource="{Binding RecentDecks}">
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="16" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ProgressText}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Học ngay" Style="{StaticResource PrimaryButton}" Width="88" Height="38" HorizontalAlignment="Right" Command="{Binding DataContext.StartLessonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Từ hôm nay" Style="{StaticResource SectionTitleText}" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}" />
        <Border Style="{StaticResource Card}" Padding="16" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <Grid Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TodayWordText}" FontSize="24" FontWeight="Bold" TextAlignment="Center" Foreground="{StaticResource IndigoBrush}" VerticalAlignment="Center" />
                        <Button Content="🔊"
                                Style="{StaticResource TodayIconButton}"
                                Foreground="{StaticResource IndigoBrush}"
                                Margin="8,0,0,0"
                                ToolTip="Nghe phát âm"
                                Command="{Binding SpeakTodayWordCommand}" />
                    </StackPanel>
                    <Button Content="{Binding TodayFavoriteIcon}"
                            Style="{StaticResource TodayIconButton}"
                            Foreground="{Binding TodayFavoriteForeground}"
                            HorizontalAlignment="Right"
                            ToolTip="Thêm vào yêu thích"
                            Command="{Binding ToggleTodayFavoriteCommand}" />
                </Grid>
                <TextBlock Text="{Binding TodayWordHint}" Style="{StaticResource MutedText}" FontSize="14" TextAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="{Binding TodayWordPrompt}" Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,0,0,14" />
                <Button Content="{Binding TodayChoiceA, StringFormat=A. {0}}" Style="{StaticResource OutlineButton}" Background="{Binding TodayChoiceABackground}" BorderBrush="{Binding TodayChoiceABorder}" IsHitTestVisible="{Binding CanSelectTodayWordAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,8" Command="{Binding SelectTodayWordAnswerCommand}" CommandParameter="0" />
                <Button Content="{Binding TodayChoiceB, StringFormat=B. {0}}" Style="{StaticResource OutlineButton}" Background="{Binding TodayChoiceBBackground}" BorderBrush="{Binding TodayChoiceBBorder}" IsHitTestVisible="{Binding CanSelectTodayWordAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,8" Command="{Binding SelectTodayWordAnswerCommand}" CommandParameter="1" />
                <Button Content="{Binding TodayChoiceC, StringFormat=C. {0}}" Style="{StaticResource OutlineButton}" Background="{Binding TodayChoiceCBackground}" BorderBrush="{Binding TodayChoiceCBorder}" IsHitTestVisible="{Binding CanSelectTodayWordAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,8" Command="{Binding SelectTodayWordAnswerCommand}" CommandParameter="2" />
                <Button Content="{Binding TodayChoiceD, StringFormat=D. {0}}" Style="{StaticResource OutlineButton}" Background="{Binding TodayChoiceDBackground}" BorderBrush="{Binding TodayChoiceDBorder}" IsHitTestVisible="{Binding CanSelectTodayWordAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding SelectTodayWordAnswerCommand}" CommandParameter="3" />
                <TextBlock Text="{Binding TodayWordResultText}" Style="{StaticResource MutedText}" TextAlignment="Center" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
