<UserControl x:Class="WordUp.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="22,18,22,22">
        <Grid>
            <Button Content="Menu" Style="{StaticResource IconButton}" Width="54" FontSize="12" HorizontalAlignment="Left" />
            <TextBlock Text="Thống kê" Style="{StaticResource PageTitleText}" FontSize="21" HorizontalAlignment="Center" />
            <Button Content="{Binding User.Initials}" Style="{StaticResource PrimaryButton}" Width="40" Height="36" HorizontalAlignment="Right" Command="{Binding NavigateCommand}" CommandParameter="Account" />
        </Grid>

        <Border Style="{StaticResource Card}" Height="220" Margin="0,22,0,14">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Mục tiêu hôm nay" FontWeight="Bold" FontSize="17" TextAlignment="Center" />
                <TextBlock Text="{Binding TodayGoalPercentage, StringFormat={}{0}%}" Foreground="{StaticResource IndigoBrush}" FontSize="34" FontWeight="Bold" TextAlignment="Center" Margin="0,22,0,4" />
                <TextBlock Text="{Binding TodayGoalText}" Style="{StaticResource MutedText}" TextAlignment="Center" />
                <TextBlock Text="Tiếp tục nhé, bạn sắp hoàn thành rồi." Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,22,0,0" />
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Tiến độ tuần" FontWeight="Bold" FontSize="17" />
                <ItemsControl ItemsSource="{Binding WeeklyProgressValues}" Height="120" Margin="0,16,0,6" VerticalAlignment="Bottom">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ProgressBar Value="{Binding Path=., Mode=OneWay}" Maximum="100" Orientation="Vertical" Foreground="{StaticResource IndigoBrush}" Margin="3,0" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="Số từ đã học mỗi ngày" Style="{StaticResource MutedText}" TextAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Thành tích" FontWeight="Bold" FontSize="17" Margin="0,0,0,12" />
                <ItemsControl ItemsSource="{Binding Achievements}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="4">
                                <StackPanel>
                                    <TextBlock Text="Huy hiệu" FontSize="14" TextAlignment="Center" Foreground="{StaticResource IndigoBrush}" />
                                    <TextBlock Text="{Binding Name}" TextAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
