<UserControl x:Class="WordUp.Views.StudyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="0">
        <Grid Background="White" Height="54">
            <Button Content="Quay lại" Style="{StaticResource IconButton}" Width="70" FontSize="12" HorizontalAlignment="Left" Command="{Binding ShowLessonListCommand}" Visibility="{Binding IsStudyFlashcardOpen, Converter={StaticResource BoolToVisibility}}" />
            <Button Content="X" Style="{StaticResource IconButton}" HorizontalAlignment="Left" Command="{Binding SelectTabCommand}" CommandParameter="Dashboard" Visibility="{Binding IsStudyLessonListVisible, Converter={StaticResource BoolToVisibility}}" />
            <TextBlock Text="{Binding StudyHeaderTitle}" Style="{StaticResource PageTitleText}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <TextBlock Text="{Binding StudyProgressText}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0" Visibility="{Binding IsStudyFlashcardOpen, Converter={StaticResource BoolToVisibility}}" />
        </Grid>

        <StackPanel Margin="22,18,22,22" Visibility="{Binding IsStudyLessonListVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="0,0,0,16">
                <TextBox Style="{StaticResource TextInput}" Text="{Binding LessonSearchText, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,0,82,0" VerticalAlignment="Center" />
                <TextBlock Text="Tìm bài học..." Style="{StaticResource MutedText}" Margin="12,0,82,0" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="{Binding ShowLessonSearchPlaceholder, Converter={StaticResource BoolToVisibility}}" />
                <Button Style="{StaticResource PrimaryButton}" Width="72" Height="38" HorizontalAlignment="Right" Command="{Binding AddLessonCommand}">
                    <TextBlock Text="Thêm" Foreground="White" />
                </Button>
            </Grid>

            <ItemsControl ItemsSource="{Binding FilteredDecks}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Padding="16" MinHeight="146" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" />
                                <TextBlock Text="{Binding UpdatedAtText}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding TotalWordsText}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                                <ProgressBar Value="{Binding ProgressPercentage, Mode=OneWay}" Maximum="100" Height="7" Foreground="{StaticResource SuccessBrush}" Margin="0,10,0,0" />
                                <TextBlock Text="{Binding ProgressText}" Style="{StaticResource MutedText}" HorizontalAlignment="Right" Margin="0,6,0,0" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                                    <Button Style="{StaticResource PrimaryButton}" Background="#5F74DC" Width="56" Height="32" Padding="10,0" Margin="0,0,7,0" Command="{Binding DataContext.EditLessonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                        <TextBlock Text="Sửa" Foreground="White" />
                                    </Button>
                                    <Button Style="{StaticResource PrimaryButton}" Background="#E05A66" Width="56" Height="32" Padding="10,0" Margin="0,0,7,0" Command="{Binding DataContext.DeleteLessonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                        <TextBlock Text="Xóa" Foreground="White" />
                                    </Button>
                                    <Button Style="{StaticResource PrimaryButton}" Background="#34B77D" Width="56" Height="32" Padding="10,0" Command="{Binding DataContext.StartLessonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                        <TextBlock Text="Học" Foreground="White" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <StackPanel Margin="22,18,22,22" Visibility="{Binding IsAddLessonOpen, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding LessonEditorTitle}" Style="{StaticResource SectionTitleText}" Margin="0,0,0,10" />
            <TextBlock Text="Tên bài học" FontWeight="SemiBold" />
            <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,14" />

            <Border Style="{StaticResource Card}" Padding="16">
                <StackPanel>
                    <TextBlock Text="Thêm từ thủ công" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12" />
                    <TextBlock Text="Từ" Style="{StaticResource MutedText}" />
                    <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonWord, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" />
                    <TextBlock Text="Nghĩa của từ" Style="{StaticResource MutedText}" />
                    <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonMeaning, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" />
                    <TextBlock Text="Loại từ" Style="{StaticResource MutedText}" />
                    <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonType, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,12" />
                    <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Command="{Binding AddLessonWordCommand}">
                        <TextBlock Text="{Binding LessonWordEditorButtonText}" Foreground="White" />
                    </Button>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="16">
                <StackPanel>
                    <TextBlock Text="Nhập từ tệp" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                    <TextBlock Text="Hỗ trợ .txt, .csv, .docx, .xlsx. Mỗi dòng hoặc hàng: từ, nghĩa, loại từ, ví dụ." Style="{StaticResource MutedText}" Margin="0,0,0,12" />
                    <Grid>
                        <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonFilePath}" IsReadOnly="True" Margin="0,0,104,0" />
                        <Button Content="Chọn tệp" Style="{StaticResource PrimaryButton}" Width="96" Height="36" HorizontalAlignment="Right" Command="{Binding ImportLessonFileCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding NewLessonMessage}" Style="{StaticResource MutedText}" Margin="0,0,0,10" />
            <TextBlock Text="Từ trong bài học" Style="{StaticResource SectionTitleText}" Margin="0,6,0,10" />
            <Grid Margin="0,0,0,10">
                <TextBox Style="{StaticResource TextInput}" Text="{Binding LessonWordSearchText, UpdateSourceTrigger=PropertyChanged}" Height="36" />
                <TextBlock Text="Tìm từ cần sửa..." Style="{StaticResource MutedText}" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="{Binding ShowLessonWordSearchPlaceholder, Converter={StaticResource BoolToVisibility}}" />
            </Grid>
            <ItemsControl ItemsSource="{Binding FilteredNewLessonWords}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                            <Grid>
                                <StackPanel Margin="0,0,132,0">
                                    <TextBlock Text="{Binding Word}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding VietnameseMeaning}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding Type}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource PrimaryButton}" Background="#5F74DC" Width="52" Height="32" Padding="8,0" Margin="0,0,7,0" Command="{Binding DataContext.EditLessonWordCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                        <TextBlock Text="Sửa" Foreground="White" />
                                    </Button>
                                    <Button Style="{StaticResource PrimaryButton}" Background="#E05A66" Width="52" Height="32" Padding="8,0" Command="{Binding DataContext.DeleteLessonWordCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                        <TextBlock Text="Xóa" Foreground="White" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <UniformGrid Columns="2" Margin="0,10,0,0">
                <Button Content="Hủy" Style="{StaticResource OutlineButton}" Margin="0,0,6,0" Command="{Binding CancelNewLessonCommand}" />
                <Button Content="{Binding SaveLessonButtonText}" Style="{StaticResource PrimaryButton}" Margin="6,0,0,0" Command="{Binding SaveNewLessonCommand}" />
            </UniformGrid>
        </StackPanel>

        <StackPanel Margin="22,18,22,22" Visibility="{Binding IsStudyFlashcardOpen, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Tiến độ ghi nhớ" Style="{StaticResource MutedText}" />
            <ProgressBar Value="{Binding StudyProgressValue, Mode=OneWay}" Maximum="100" Height="7" Margin="0,6,0,18" Foreground="{StaticResource IndigoBrush}" />
            <Button Background="Transparent" BorderThickness="0" Command="{Binding FlipFlashcardCommand}">
                <Border Style="{StaticResource Card}" Height="330" Padding="24">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" Visibility="{Binding IsFlashcardBackVisible, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                            <TextBlock Text="{Binding CurrentWord.Word}" Style="{StaticResource PageTitleText}" TextAlignment="Center" />
                            <Border Background="#F0EEFA" CornerRadius="16" Padding="12,5" HorizontalAlignment="Center" Margin="0,12,0,24">
                                <TextBlock Text="{Binding CurrentWord.Ipa}" Style="{StaticResource MutedText}" />
                            </Border>
                            <TextBlock Text="Phát âm" Foreground="{StaticResource IndigoBrush}" FontSize="22" TextAlignment="Center" />
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center" Visibility="{Binding IsFlashcardBackVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding CurrentWord.VietnameseMeaning}" FontSize="24" FontWeight="Bold" TextAlignment="Center" />
                            <TextBlock Text="{Binding CurrentWord.Type}" Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,8,0,18" />
                            <TextBlock Text="{Binding CurrentWord.Example}" TextAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding FlashcardHint}" Style="{StaticResource MutedText}" HorizontalAlignment="Center" VerticalAlignment="Bottom" />
                    </Grid>
                </Border>
            </Button>
            <UniformGrid Columns="3" Visibility="{Binding IsFlashcardBackVisible, Converter={StaticResource BoolToVisibility}}">
                <Button Content="Chưa thuộc" Style="{StaticResource OutlineButton}" Margin="0,0,6,0" Command="{Binding NextWordCommand}" CommandParameter="0" />
                <Button Content="Bình thường" Style="{StaticResource OutlineButton}" Margin="6,0" Command="{Binding NextWordCommand}" CommandParameter="1" />
                <Button Content="Đã thuộc" Style="{StaticResource PrimaryButton}" Margin="6,0,0,0" Command="{Binding NextWordCommand}" CommandParameter="2" />
            </UniformGrid>
        </StackPanel>
    </StackPanel>
</UserControl>
