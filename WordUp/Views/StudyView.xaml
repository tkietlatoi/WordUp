<UserControl x:Class="WordUp.Views.StudyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="StudyIconButton" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="21" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="20" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F0EEFA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FlashcardFlipButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StudyCloseButton" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource IndigoDarkBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="0">
        <Grid Background="White" Height="54">
            <Button Content="X" Style="{StaticResource StudyCloseButton}" HorizontalAlignment="Left" Command="{Binding ShowLessonListCommand}" Visibility="{Binding IsStudyFlashcardOpen, Converter={StaticResource BoolToVisibility}}" />
            <TextBlock Text="{Binding StudyHeaderTitle}" Style="{StaticResource PageTitleText}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <TextBlock Text="{Binding StudyProgressText}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0" Visibility="{Binding IsStudyFlashcardOpen, Converter={StaticResource BoolToVisibility}}" />
        </Grid>

        <StackPanel Margin="22,18,22,22" Visibility="{Binding IsStudyLessonListVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="0,0,0,16">
                <TextBox Style="{StaticResource TextInput}" Text="{Binding LessonSearchText, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,0,82,0" VerticalAlignment="Center" />
                <TextBlock Text="Tìm bài học..." Style="{StaticResource MutedText}" Margin="12,0,82,0" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="{Binding ShowLessonSearchPlaceholder, Converter={StaticResource BoolToVisibility}}" />
                <Button Style="{StaticResource PrimaryButton}" Foreground="#111322" Width="72" Height="38" HorizontalAlignment="Right" Command="{Binding AddLessonCommand}">
                    <TextBlock Text="Thêm" Foreground="#111322" />
                </Button>
            </Grid>

            <ItemsControl ItemsSource="{Binding FilteredDecks}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Padding="16" MinHeight="146" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" />
                                <TextBlock Text="{Binding UpdatedAtText}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding TotalWordsText}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                                <ProgressBar Value="{Binding ProgressPercentage, Mode=OneWay}" Maximum="100" Height="7" Foreground="{StaticResource SuccessBrush}" Margin="0,10,0,0" />
                                <TextBlock Text="{Binding ProgressText}" Style="{StaticResource MutedText}" HorizontalAlignment="Right" Margin="0,6,0,0" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                                    <Button Style="{StaticResource PrimaryButton}" Background="#5F74DC" Foreground="#111322" Width="56" Height="32" Padding="10,0" Margin="0,0,7,0" Command="{Binding DataContext.EditLessonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                        <TextBlock Text="Sửa" Foreground="#111322" />
                                    </Button>
                                    <Button Style="{StaticResource PrimaryButton}" Background="#E05A66" Foreground="#111322" Width="56" Height="32" Padding="10,0" Margin="0,0,7,0" Command="{Binding DataContext.DeleteLessonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                        <TextBlock Text="Xóa" Foreground="#111322" />
                                    </Button>
                                    <Button Style="{StaticResource PrimaryButton}" Background="#34B77D" Foreground="#111322" Width="56" Height="32" Padding="10,0" Command="{Binding DataContext.StartLessonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                        <TextBlock Text="Học" Foreground="#111322" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <StackPanel Margin="22,18,22,22" Visibility="{Binding IsAddLessonOpen, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding LessonEditorTitle}" Style="{StaticResource SectionTitleText}" Margin="0,0,0,10" />
            <TextBlock Text="Tên bài học" FontWeight="SemiBold" />
            <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,14" />

            <Border Style="{StaticResource Card}" Padding="16">
                <StackPanel>
                    <TextBlock Text="Thêm từ thủ công" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12" />
                    <TextBlock Text="Từ" Style="{StaticResource MutedText}" />
                    <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonWord, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" />
                    <TextBlock Text="IPA" Style="{StaticResource MutedText}" />
                    <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonIpa, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" />
                    <TextBlock Text="Nghĩa của từ" Style="{StaticResource MutedText}" />
                    <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonMeaning, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" />
                    <TextBlock Text="Loại từ" Style="{StaticResource MutedText}" />
                    <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonType, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,12" />
                    <Button Style="{StaticResource PrimaryButton}" Foreground="#111322" HorizontalAlignment="Right" Command="{Binding AddLessonWordCommand}">
                        <TextBlock Text="{Binding LessonWordEditorButtonText}" Foreground="#111322" />
                    </Button>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="16">
                <StackPanel>
                    <TextBlock Text="Nhập từ tệp" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                    <TextBlock Text="Hỗ trợ .txt, .csv, .docx, .xlsx. Mỗi dòng/hàng cần ít nhất: từ, nghĩa. Ví dụ: teacher, giáo viên, noun hoặc teacher - giáo viên - noun." Style="{StaticResource MutedText}" Margin="0,0,0,12" TextWrapping="Wrap" />
                    <Grid>
                        <TextBox Style="{StaticResource TextInput}" Text="{Binding NewLessonFilePath}" IsReadOnly="True" Margin="0,0,104,0" />
                        <Button Content="Chọn tệp" Style="{StaticResource PrimaryButton}" Foreground="#111322" Width="96" Height="36" HorizontalAlignment="Right" Command="{Binding ImportLessonFileCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding NewLessonMessage}" Style="{StaticResource MutedText}" Margin="0,0,0,10" />
            <TextBlock Text="Từ trong bài học" Style="{StaticResource SectionTitleText}" Margin="0,6,0,10" />
            <Grid Margin="0,0,0,10">
                <TextBox Style="{StaticResource TextInput}" Text="{Binding LessonWordSearchText, UpdateSourceTrigger=PropertyChanged}" Height="36" />
                <TextBlock Text="Tìm từ cần sửa..." Style="{StaticResource MutedText}" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="{Binding ShowLessonWordSearchPlaceholder, Converter={StaticResource BoolToVisibility}}" />
            </Grid>
            <Border Style="{StaticResource Card}" Padding="10" MaxHeight="360" Margin="0,0,0,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredNewLessonWords}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                    <Grid>
                                        <StackPanel Margin="0,0,132,0">
                                            <TextBlock Text="{Binding Word}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Ipa}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding VietnameseMeaning}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Type}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource PrimaryButton}" Background="#5F74DC" Foreground="#111322" Width="52" Height="32" Padding="8,0" Margin="0,0,7,0" Command="{Binding DataContext.EditLessonWordCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                                <TextBlock Text="Sửa" Foreground="#111322" />
                                            </Button>
                                            <Button Style="{StaticResource PrimaryButton}" Background="#E05A66" Foreground="#111322" Width="52" Height="32" Padding="8,0" Command="{Binding DataContext.DeleteLessonWordCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                                <TextBlock Text="Xóa" Foreground="#111322" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <UniformGrid Columns="2" Margin="0,10,0,0">
                <Button Content="Hủy" Style="{StaticResource OutlineButton}" Margin="0,0,6,0" Command="{Binding CancelNewLessonCommand}" />
                <Button Content="{Binding SaveLessonButtonText}" Style="{StaticResource PrimaryButton}" Foreground="#111322" Margin="6,0,0,0" Command="{Binding SaveNewLessonCommand}" />
            </UniformGrid>
        </StackPanel>

        <Grid Margin="22,18,22,22" Visibility="{Binding IsStudyFlashcardOpen, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
            <TextBlock Text="Tiến độ thẻ" Style="{StaticResource MutedText}" />
            <ProgressBar Value="{Binding StudyProgressValue, Mode=OneWay}" Maximum="100" Height="7" Margin="0,6,0,18" Foreground="{StaticResource IndigoBrush}" />
            <Border Style="{StaticResource Card}" Height="330" Padding="24">
                <Grid>
                    <Button Style="{StaticResource FlashcardFlipButton}" Command="{Binding FlipFlashcardCommand}" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Panel.ZIndex="2">
                        <Button Content="🔊" Style="{StaticResource StudyIconButton}" Foreground="{StaticResource IndigoBrush}" Margin="0,0,4,0" ToolTip="Nghe phát âm" Command="{Binding SpeakCurrentWordCommand}" />
                        <Button Content="{Binding StudyFavoriteIcon}" Style="{StaticResource StudyIconButton}" Foreground="{Binding StudyFavoriteForeground}" ToolTip="Yêu thích" Command="{Binding ToggleCurrentFavoriteCommand}" />
                    </StackPanel>

                    <StackPanel IsHitTestVisible="False" VerticalAlignment="Center" Margin="10,36,10,34" Visibility="{Binding IsFlashcardBackVisible, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <TextBlock Text="{Binding CurrentWord.Word}" Style="{StaticResource PageTitleText}" TextAlignment="Center" FontSize="34" />
                        <Border Background="#F0EEFA" CornerRadius="16" Padding="12,5" HorizontalAlignment="Center" Margin="0,14,0,18">
                            <TextBlock Text="{Binding CurrentWord.Ipa}" Style="{StaticResource MutedText}" />
                        </Border>
                        <TextBlock Text="{Binding CurrentWord.Type}" Style="{StaticResource MutedText}" TextAlignment="Center" />
                    </StackPanel>

                    <StackPanel IsHitTestVisible="False" VerticalAlignment="Center" Margin="10,36,10,34" Visibility="{Binding IsFlashcardBackVisible, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding CurrentWord.VietnameseMeaning}" Style="{StaticResource PageTitleText}" TextAlignment="Center" FontSize="30" TextWrapping="Wrap" />
                        <Border Background="#F0EEFA" CornerRadius="16" Padding="12,5" HorizontalAlignment="Center" Margin="0,14,0,18">
                            <TextBlock Text="{Binding CurrentWord.Type}" Style="{StaticResource MutedText}" />
                        </Border>
                        <TextBlock Text="{Binding CurrentWord.Example}" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock IsHitTestVisible="False" Text="{Binding FlashcardHint}" Style="{StaticResource MutedText}" HorizontalAlignment="Center" VerticalAlignment="Bottom" />
                </Grid>
            </Border>
            <UniformGrid Columns="3" Margin="0,14,0,0">
                <Button Content="&lt;" Style="{StaticResource OutlineButton}" FontSize="20" Margin="0,0,6,0" Command="{Binding PreviousWordCommand}" />
                <Button Content="&gt;" Style="{StaticResource OutlineButton}" FontSize="20" Margin="6,0" Command="{Binding NextWordCommand}" />
                <Button Content="{Binding StudyAutoButtonText}" Style="{StaticResource PrimaryButton}" Foreground="#111322" FontSize="18" Margin="6,0,0,0" ToolTip="Tự động" Command="{Binding ToggleStudyAutoCommand}" />
            </UniformGrid>
            </StackPanel>

            <Border Visibility="{Binding IsLessonCompleteDialogOpen, Converter={StaticResource BoolToVisibility}}">
                <Border Style="{StaticResource Card}" Padding="18" Width="300" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Hoàn thành bài học" Style="{StaticResource SectionTitleText}" TextAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="Bạn đã học hết các thẻ trong bài này." Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,0,0,16" />
                        <Button Content="Học lại" Style="{StaticResource PrimaryButton}" Foreground="#111322" Margin="0,0,0,8" Command="{Binding RestartLessonCommand}" />
                        <Button Content="Quay lại bài học" Style="{StaticResource OutlineButton}" Margin="0,0,0,8" Command="{Binding BackToLessonsFromCompleteCommand}" />
                        <Button Content="Làm bài kiểm tra" Style="{StaticResource PrimaryButton}" Foreground="#111322" Command="{Binding StartQuizFromLessonCommand}" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
