<UserControl x:Class="WordUp.Views.QuizResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="22,18,22,22">
        <Grid>
            <Button Content="Quay lại" Style="{StaticResource IconButton}" Width="70" FontSize="12" HorizontalAlignment="Left" Command="{Binding NavigateCommand}" CommandParameter="Quiz" />
            <TextBlock Text="Kết quả bài kiểm tra" Style="{StaticResource PageTitleText}" FontSize="21" HorizontalAlignment="Center" />
        </Grid>
        <Border Style="{StaticResource Card}" Height="210" Margin="0,18,0,18">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding QuizScorePercentage, StringFormat={}{0}%}" Foreground="{StaticResource IndigoBrush}" FontSize="38" FontWeight="Bold" TextAlignment="Center" />
                <TextBlock Text="{Binding QuizScoreText}" FontSize="16" TextAlignment="Center" Margin="0,12,0,4" />
                <TextBlock Text="Bạn đã hoàn thành bài kiểm tra." Style="{StaticResource MutedText}" TextAlignment="Center" />
            </StackPanel>
        </Border>
        <TextBlock Text="Chi tiết câu hỏi" Style="{StaticResource SectionTitleText}" />
        <ItemsControl ItemsSource="{Binding QuizQuestions}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="14">
                        <Grid>
                            <TextBlock Text="{Binding StatusSymbol}" Width="30" Height="30" TextAlignment="Center" VerticalAlignment="Top" FontWeight="Bold" Foreground="{StaticResource IndigoBrush}" />
                            <StackPanel Margin="40,0,0,0">
                                <TextBlock Text="{Binding Term, StringFormat=Câu hỏi: {0}}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedChoice, StringFormat=Đã chọn: {0}}" Style="{StaticResource MutedText}" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding CorrectChoice, StringFormat=Đáp án đúng: {0}}" Foreground="{StaticResource SuccessBrush}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <UniformGrid Columns="2">
            <Button Content="Làm lại" Style="{StaticResource OutlineButton}" Margin="0,0,8,0" Command="{Binding ResetQuizCommand}" />
            <Button Content="Hoàn thành" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Command="{Binding SelectTabCommand}" CommandParameter="Dashboard" />
        </UniformGrid>
    </StackPanel>
</UserControl>
