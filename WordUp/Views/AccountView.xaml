<UserControl x:Class="WordUp.Views.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="22,18,22,22">
        <Grid>
            <Border Width="58" Height="58" CornerRadius="29" Background="#F0EEFA" HorizontalAlignment="Left">
                <TextBlock Text="{Binding User.Initials}" Foreground="{StaticResource IndigoBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Margin="72,0,70,0">
                <TextBlock Text="{Binding User.FullName}" Style="{StaticResource PageTitleText}" FontSize="19" />
                <TextBlock Text="Thành viên Pro" Style="{StaticResource MutedText}" />
            </StackPanel>
            <Button Content="Quay lại" Style="{StaticResource IconButton}" Width="70" FontSize="12" HorizontalAlignment="Right" Command="{Binding SelectTabCommand}" CommandParameter="Dashboard" />
        </Grid>
        <TextBlock Text="QUẢN LÝ TÀI KHOẢN" Style="{StaticResource MutedText}" Margin="0,24,0,18" />
        <Button Content="Sửa hồ sơ >" Style="{StaticResource OutlineButton}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding NavigateCommand}" CommandParameter="Profile" />
        <Button Content="Giới thiệu WordUp >" Style="{StaticResource OutlineButton}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding NavigateCommand}" CommandParameter="About" />
        <Button Content="Cài đặt chung >" Style="{StaticResource OutlineButton}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding NavigateCommand}" CommandParameter="Settings" />
        <CheckBox Content="Giao diện tối" Margin="0,14,0,18" />
        <Button Content="Xóa tài khoản >" Style="{StaticResource DangerButton}" HorizontalContentAlignment="Left" Margin="0,0,0,220" Command="{Binding DeleteAccountCommand}" />
        <Button Content="Đăng xuất" Style="{StaticResource DangerButton}" Command="{Binding LogoutCommand}" />
    </StackPanel>
</UserControl>
