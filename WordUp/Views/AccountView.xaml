<UserControl x:Class="WordUp.Views.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="AccountAvatarButton" TargetType="Button">
            <Setter Property="Width" Value="82" />
            <Setter Property="Height" Value="82" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="58" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" CornerRadius="15" Background="{DynamicResource BorderBrush}">
                            <Ellipse x:Name="Thumb" Width="24" Height="24" Fill="{DynamicResource SurfaceBrush}" HorizontalAlignment="Left" Margin="3,0,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource IndigoBrush}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.78" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Background="{DynamicResource SurfaceBrush}">
            <TextBlock Text="Cá nhân" Style="{StaticResource PageTitleText}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    <StackPanel Grid.Row="1" Margin="22,18,22,22">
        <Grid>
            <Button Style="{StaticResource AccountAvatarButton}" HorizontalAlignment="Left" Command="{Binding OpenAvatarDialogCommand}">
                <Grid Width="82" Height="82">
                    <Ellipse Fill="#F0EEFA" />
                    <Ellipse Visibility="{Binding User.HasAvatar, Converter={StaticResource BoolToVisibility}}">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding User.AvatarImage}" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding User.Initials}" Foreground="{StaticResource IndigoBrush}" FontWeight="Bold" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding User.HasAvatar, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                </Grid>
            </Button>
            <StackPanel Margin="98,4,52,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding User.FullName}" Style="{StaticResource PageTitleText}" FontSize="26" TextWrapping="Wrap" />
                <TextBlock Text="{Binding DashboardSubtitle}" Style="{StaticResource MutedText}" FontSize="13" Margin="0,6,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
        <TextBlock Text="QUẢN LÝ TÀI KHOẢN" Foreground="{DynamicResource IndigoDarkBrush}" FontSize="17" FontWeight="SemiBold" TextAlignment="Center" Margin="0,28,0,18" />
        <Button Content="✎  Sửa hồ sơ  >" Style="{StaticResource OutlineButton}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding NavigateCommand}" CommandParameter="Profile" />
        <Button Content="ⓘ  Giới thiệu WordUp  >" Style="{StaticResource OutlineButton}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding NavigateCommand}" CommandParameter="About" />
        <Button Content="⚙  Cài đặt chung  >" Style="{StaticResource OutlineButton}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding NavigateCommand}" CommandParameter="Settings" />
        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14,10" Margin="0,14,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Giao diện tối" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ToggleButton Grid.Column="1" Style="{StaticResource ThemeSwitch}" IsChecked="{Binding IsDarkMode, Mode=TwoWay}" />
            </Grid>
        </Border>
        <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Hồ sơ học tập" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Thông tin cá nhân, ghi chú trang chủ và các cài đặt học tập của bạn được lưu trên thiết bị này để WordUp cá nhân hóa trải nghiệm học từ vựng." Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        <Button Content="Xóa tài khoản" Style="{StaticResource DangerButton}" HorizontalContentAlignment="Center" Margin="0,0,0,12" Command="{Binding DeleteAccountCommand}" />
        <Button Content="↪  Đăng xuất" Style="{StaticResource OutlineButton}" Command="{Binding LogoutCommand}" />
    </StackPanel>

    <Border Grid.Row="1" Background="#66000000" Visibility="{Binding IsDeleteAccountDialogOpen, Converter={StaticResource BoolToVisibility}}">
        <Border Style="{StaticResource Card}" Padding="18" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Xóa tài khoản?" Style="{StaticResource SectionTitleText}" TextAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Thao tác này sẽ xóa tài khoản và dữ liệu học tập được lưu trên máy này. Bạn có chắc muốn tiếp tục không?" Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,16" />
                <UniformGrid Columns="2">
                    <Button Content="Hủy" Style="{StaticResource OutlineButton}" Margin="0,0,6,0" Command="{Binding CancelDeleteAccountCommand}" />
                    <Button Content="Xóa" Style="{StaticResource DangerButton}" Margin="6,0,0,0" Command="{Binding ConfirmDeleteAccountCommand}" />
                </UniformGrid>
            </StackPanel>
        </Border>
    </Border>

    <Border Grid.Row="1" Background="#66000000" Visibility="{Binding IsAvatarDialogOpen, Converter={StaticResource BoolToVisibility}}">
        <Border Style="{StaticResource Card}" Padding="18" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Ảnh đại diện" Style="{StaticResource SectionTitleText}" TextAlignment="Center" Margin="0,0,0,12" />
                <Grid Width="150" Height="150" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Ellipse Fill="#F0EEFA" />
                    <Ellipse Visibility="{Binding User.HasAvatar, Converter={StaticResource BoolToVisibility}}">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding User.AvatarImage}" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding User.Initials}" Foreground="{StaticResource IndigoBrush}" FontWeight="Bold" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding User.HasAvatar, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                </Grid>
                <Button Content="Nhập" Style="{StaticResource PrimaryButton}" Margin="0,0,0,10" Command="{Binding ImportAvatarCommand}" />
                <Button Content="Đóng" Style="{StaticResource OutlineButton}" Command="{Binding CloseAvatarDialogCommand}" />
            </StackPanel>
        </Border>
    </Border>

    <Border Background="#66000000" Visibility="{Binding IsLogoutDialogOpen, Converter={StaticResource BoolToVisibility}}">
        <Border Style="{StaticResource Card}" Padding="18" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Đăng xuất?" Style="{StaticResource SectionTitleText}" TextAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Bạn có chắc muốn đăng xuất khỏi tài khoản hiện tại không?" Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,16" />
                <UniformGrid Columns="2">
                    <Button Content="Hủy" Style="{StaticResource OutlineButton}" Margin="0,0,6,0" Command="{Binding CancelLogoutCommand}" />
                    <Button Content="Đăng xuất" Style="{StaticResource PrimaryButton}" Margin="6,0,0,0" Command="{Binding ConfirmLogoutCommand}" />
                </UniformGrid>
            </StackPanel>
        </Border>
    </Border>
    </Grid>
</UserControl>
