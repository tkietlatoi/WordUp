<UserControl x:Class="WordUp.Views.QuizView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="PracticeSettingsButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource IndigoDarkBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PracticeTabButton" TargetType="Button" BasedOn="{StaticResource TextLinkButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border x:Name="Indicator" Width="72" Height="3" CornerRadius="2" Background="{DynamicResource IndigoBrush}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource IndigoDarkBrush}" />
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource IndigoBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PracticeSourceRadio" TargetType="RadioButton">
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource IndigoBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Border Width="15" Height="15" CornerRadius="8" BorderBrush="{TemplateBinding Foreground}" BorderThickness="2" VerticalAlignment="Center">
                                    <Ellipse x:Name="Dot" Fill="{TemplateBinding Foreground}" Margin="3" Visibility="Collapsed" />
                                </Border>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource IndigoBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource IndigoBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="22,18,22,22">
        <StackPanel Visibility="{Binding IsQuizIntroVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Button Content="x" Style="{StaticResource IconButton}" HorizontalAlignment="Left" Command="{Binding SelectTabCommand}" CommandParameter="Dashboard" />
                <TextBlock Text="Luyện tập" Style="{StaticResource PageTitleText}" FontSize="21" HorizontalAlignment="Center" />
            </Grid>

            <Grid Width="230" HorizontalAlignment="Center" Margin="0,18,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="38" />
                    <RowDefinition Height="4" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Content="Luyện tập" Style="{StaticResource PracticeTabButton}" Tag="{Binding IsPracticeTab}" Command="{Binding SelectPracticeTabCommand}" CommandParameter="Practice" />
                <Button Grid.Column="1" Content="Thống kê" Style="{StaticResource PracticeTabButton}" Tag="{Binding IsPracticeStatsTab}" Command="{Binding SelectPracticeTabCommand}" CommandParameter="Stats" />
                <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{DynamicResource BorderBrush}" Height="1" VerticalAlignment="Top" />
            </Grid>

            <Border Style="{StaticResource Card}" Padding="16" Visibility="{Binding IsPracticeTab, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <StackPanel Margin="0,8,0,0" Panel.ZIndex="0">
                        <TextBlock Text="Ôn tập toàn bộ từ vựng" Style="{StaticResource SectionTitleText}" TextAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="Bạn sẽ luyện tập các từ đã học trong tất cả bài học. WordUp sẽ trộn câu hỏi để kiểm tra mức độ ghi nhớ, phát hiện những từ còn yếu và theo dõi tiến bộ sau mỗi lần luyện tập." Style="{StaticResource MutedText}" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,18" />
                        <Button Content="Bắt đầu" Style="{StaticResource PrimaryButton}" Command="{Binding StartPracticeCommand}" />
                    </StackPanel>
                    <Button Content="⚙" Style="{StaticResource PracticeSettingsButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Panel.ZIndex="2" Command="{Binding ToggleQuizSettingsCommand}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource Card}" Padding="18" Visibility="{Binding IsPracticeStatsTab, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tỷ lệ thuộc từ" FontSize="17" FontWeight="Bold" />
                            <TextBlock Text="{Binding PracticeMasteryText}" Style="{StaticResource MutedText}" FontSize="14" Margin="0,5,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding PracticeCoverageText}" Style="{StaticResource MutedText}" FontSize="14" Margin="0,3,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PracticeMasteryPercentage, StringFormat={}{0}%}" Foreground="{DynamicResource IndigoDarkBrush}" FontSize="38" FontWeight="Bold" TextAlignment="Right" />
                            <TextBlock Text="{Binding PracticeMasteryLabel}" Style="{StaticResource MutedText}" FontSize="14" TextAlignment="Right" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                    <ProgressBar Value="{Binding PracticeMasteryPercentage, Mode=OneWay}" Maximum="100" Height="8" Foreground="{DynamicResource IndigoBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="Biểu đồ phân bố ghi nhớ" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="{Binding PracticeNewBar, StringFormat={}{0:0}%}" FontSize="14" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,4" />
                            <ProgressBar Value="{Binding PracticeNewBar, Mode=OneWay}" Maximum="100" Width="26" Height="104" HorizontalAlignment="Center" Orientation="Vertical" Foreground="{DynamicResource BorderBrush}" />
                            <TextBlock Text="Mới" Style="{StaticResource MutedText}" FontSize="14" TextAlignment="Center" Margin="0,7,0,0" />
                            <TextBlock Text="{Binding PracticeNewCountText}" Style="{StaticResource MutedText}" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0">
                            <TextBlock Text="{Binding PracticeWeakBar, StringFormat={}{0:0}%}" FontSize="14" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,4" />
                            <ProgressBar Value="{Binding PracticeWeakBar, Mode=OneWay}" Maximum="100" Width="26" Height="104" HorizontalAlignment="Center" Orientation="Vertical" Foreground="{DynamicResource DangerBrush}" />
                            <TextBlock Text="Yếu" Style="{StaticResource MutedText}" FontSize="14" TextAlignment="Center" Margin="0,7,0,0" />
                            <TextBlock Text="{Binding PracticeWeakCountText}" Style="{StaticResource MutedText}" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="5,0">
                            <TextBlock Text="{Binding PracticeLearningBar, StringFormat={}{0:0}%}" FontSize="14" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,4" />
                            <ProgressBar Value="{Binding PracticeLearningBar, Mode=OneWay}" Maximum="100" Width="26" Height="104" HorizontalAlignment="Center" Orientation="Vertical" Foreground="#E0A12F" />
                            <TextBlock Text="Đang nhớ" Style="{StaticResource MutedText}" FontSize="14" TextAlignment="Center" Margin="0,7,0,0" />
                            <TextBlock Text="{Binding PracticeLearningCountText}" Style="{StaticResource MutedText}" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="5,0,0,0">
                            <TextBlock Text="{Binding PracticeGoodBar, StringFormat={}{0:0}%}" FontSize="14" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,4" />
                            <ProgressBar Value="{Binding PracticeGoodBar, Mode=OneWay}" Maximum="100" Width="26" Height="104" HorizontalAlignment="Center" Orientation="Vertical" Foreground="{DynamicResource SuccessBrush}" />
                            <TextBlock Text="Tốt" Style="{StaticResource MutedText}" FontSize="14" TextAlignment="Center" Margin="0,7,0,0" />
                            <TextBlock Text="{Binding PracticeGoodCountText}" Style="{StaticResource MutedText}" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,16,0,0">
                        <Border Background="{DynamicResource HoverSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,9" Margin="0,0,0,8">
                            <TextBlock Text="{Binding PracticeTotalWordsLine}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                        </Border>
                        <Border Background="{DynamicResource HoverSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,9" Margin="0,0,0,8">
                            <TextBlock Text="{Binding PracticeTotalAttemptsLine}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                        </Border>
                        <Border Background="{DynamicResource HoverSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,9" Margin="0,0,0,8">
                            <TextBlock Text="{Binding PracticeStudiedTodayLine}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                        </Border>
                        <Border Background="{DynamicResource HoverSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,9" Margin="0,0,0,8">
                            <TextBlock Text="{Binding PracticeMasteredWordsLine}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                        </Border>
                        <Border Background="{DynamicResource HoverSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,9">
                            <TextBlock Text="{Binding PracticeLastReviewedLine}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Visibility="{Binding IsQuizInProgress, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Button Content="x" Style="{StaticResource IconButton}" HorizontalAlignment="Left" Command="{Binding SelectTabCommand}" CommandParameter="Quiz" />
                <TextBlock Text="Làm bài luyện tập" Style="{StaticResource PageTitleText}" FontSize="21" HorizontalAlignment="Center" />
                <Button Content="Nộp" Style="{StaticResource PrimaryButton}" Width="76" Height="36" Padding="12,0" HorizontalAlignment="Right" Command="{Binding SubmitQuizCommand}" />
            </Grid>

            <Grid Margin="0,20,0,6">
                <TextBlock Text="{Binding QuizProgressText}" Style="{StaticResource MutedText}" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding QuizElapsedTimeText}" Style="{StaticResource MutedText}" FontWeight="SemiBold" HorizontalAlignment="Right" />
            </Grid>
            <ProgressBar Value="{Binding QuizProgressValue, Mode=OneWay}" Maximum="100" Height="7" Foreground="{DynamicResource IndigoBrush}" />

            <Border Style="{StaticResource Card}" Height="190" Margin="0,24,0,18">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentQuizQuestion.Term}" FontSize="24" FontWeight="Bold" TextAlignment="Center" />
                    <TextBlock Text="{Binding CurrentQuizQuestion.Prompt}" Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <Button Content="{Binding CurrentQuizQuestion.Choices[0], StringFormat=A   {0}}" Style="{StaticResource OutlineButton}" Background="{Binding CurrentQuizQuestion.ChoiceABackground}" BorderBrush="{Binding CurrentQuizQuestion.ChoiceABorder}" IsHitTestVisible="{Binding CurrentQuizQuestion.CanSelectAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding SelectQuizAnswerCommand}" CommandParameter="0" />
            <Button Content="{Binding CurrentQuizQuestion.Choices[1], StringFormat=B   {0}}" Style="{StaticResource OutlineButton}" Background="{Binding CurrentQuizQuestion.ChoiceBBackground}" BorderBrush="{Binding CurrentQuizQuestion.ChoiceBBorder}" IsHitTestVisible="{Binding CurrentQuizQuestion.CanSelectAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding SelectQuizAnswerCommand}" CommandParameter="1" />
            <Button Content="{Binding CurrentQuizQuestion.Choices[2], StringFormat=C   {0}}" Style="{StaticResource OutlineButton}" Background="{Binding CurrentQuizQuestion.ChoiceCBackground}" BorderBrush="{Binding CurrentQuizQuestion.ChoiceCBorder}" IsHitTestVisible="{Binding CurrentQuizQuestion.CanSelectAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding SelectQuizAnswerCommand}" CommandParameter="2" />
            <Button Content="{Binding CurrentQuizQuestion.Choices[3], StringFormat=D   {0}}" Style="{StaticResource OutlineButton}" Background="{Binding CurrentQuizQuestion.ChoiceDBackground}" BorderBrush="{Binding CurrentQuizQuestion.ChoiceDBorder}" IsHitTestVisible="{Binding CurrentQuizQuestion.CanSelectAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,18" Command="{Binding SelectQuizAnswerCommand}" CommandParameter="3" />

            <UniformGrid Columns="2">
                <Button Content="&lt;" Style="{StaticResource OutlineButton}" FontSize="20" Margin="0,0,6,0" Command="{Binding PreviousQuizCommand}" />
                <Button Content="&gt;" Style="{StaticResource OutlineButton}" FontSize="20" Margin="6,0,0,0" Command="{Binding NextQuizCommand}" />
            </UniformGrid>
        </StackPanel>

        <Border Visibility="{Binding IsQuizSettingsOpen, Converter={StaticResource BoolToVisibility}}" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="10">
            <Border Style="{StaticResource Card}" Padding="14" Width="310" MaxWidth="310" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Cài đặt bài luyện tập" Style="{StaticResource SectionTitleText}" TextAlignment="Center" Margin="34,0,34,0" />
                        <Button Content="x" Style="{StaticResource IconButton}" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding CloseQuizSettingsCommand}" />
                    </Grid>
                    <TextBlock Text="Thiết lập số lượng và nguồn từ trước khi bắt đầu luyện tập." Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Số từ" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <Button Content="-" Style="{StaticResource OutlineButton}" Width="40" Height="36" Padding="0" Command="{Binding DecreaseQuizQuestionLimitCommand}" />
                        <TextBox Grid.Column="1" Style="{StaticResource TextInput}" Text="{Binding QuizQuestionLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" FontSize="16" FontWeight="SemiBold" Margin="8,0" />
                        <Button Grid.Column="2" Content="+" Style="{StaticResource OutlineButton}" Width="40" Height="36" Padding="0" Command="{Binding IncreaseQuizQuestionLimitCommand}" />
                    </Grid>

                    <TextBlock Text="Nguồn từ luyện tập" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <RadioButton Content="Những từ đã học" GroupName="PracticeWordSource" Style="{StaticResource PracticeSourceRadio}" IsChecked="{Binding IsLearnedPracticeSource, Mode=OneWay}" Command="{Binding SelectPracticeWordSourceCommand}" CommandParameter="Learned" />
                    <RadioButton Content="Từ đã đánh dấu sao" GroupName="PracticeWordSource" Style="{StaticResource PracticeSourceRadio}" IsChecked="{Binding IsFavoritePracticeSource, Mode=OneWay}" Command="{Binding SelectPracticeWordSourceCommand}" CommandParameter="Favorite" />
                    <RadioButton Content="Tất cả các từ" GroupName="PracticeWordSource" Style="{StaticResource PracticeSourceRadio}" IsChecked="{Binding IsAllPracticeSource, Mode=OneWay}" Command="{Binding SelectPracticeWordSourceCommand}" CommandParameter="All" Margin="0,0,0,16" />

                    <Button Content="Bắt đầu luyện tập" Style="{StaticResource PrimaryButton}" Height="36" HorizontalAlignment="Stretch" Command="{Binding StartPracticeCommand}" />
                </StackPanel>
            </Border>
        </Border>

        <Border Visibility="{Binding IsIncompleteQuizSubmitDialogOpen, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource Card}" Padding="18" Width="340" MaxWidth="340" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Chưa làm đủ câu" Style="{StaticResource SectionTitleText}" TextAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding IncompleteQuizSubmitText}" Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,16" />
                    <UniformGrid Columns="2">
                        <Button Content="Quay lại" Style="{StaticResource OutlineButton}" Margin="0,0,6,0" Command="{Binding ContinueQuizCommand}" />
                        <Button Content="Nộp" Style="{StaticResource PrimaryButton}" Margin="6,0,0,0" Command="{Binding ForceSubmitQuizCommand}" />
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
