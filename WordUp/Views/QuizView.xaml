<UserControl x:Class="WordUp.Views.QuizView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22,18,22,22">
        <StackPanel>
            <Grid>
                <Button Content="x" Style="{StaticResource IconButton}" HorizontalAlignment="Left" Command="{Binding SelectTabCommand}" CommandParameter="Study" />
                <TextBlock Text="Kiểm tra" Style="{StaticResource PageTitleText}" FontSize="21" HorizontalAlignment="Center" />
                <Button Content="Nộp" Style="{StaticResource PrimaryButton}" Foreground="#111322" Width="76" Height="36" Padding="12,0" HorizontalAlignment="Right" Command="{Binding SubmitQuizCommand}" />
            </Grid>

            <Grid Margin="0,20,0,6">
                <TextBlock Text="{Binding QuizProgressText}" Style="{StaticResource MutedText}" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding QuizElapsedTimeText}" Style="{StaticResource MutedText}" FontWeight="SemiBold" HorizontalAlignment="Right" />
            </Grid>
            <ProgressBar Value="{Binding QuizProgressValue, Mode=OneWay}" Maximum="100" Height="7" Foreground="{StaticResource IndigoBrush}" />

            <Border Style="{StaticResource Card}" Height="190" Margin="0,24,0,18">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentQuizQuestion.Term}" FontSize="24" FontWeight="Bold" TextAlignment="Center" />
                    <TextBlock Text="{Binding CurrentQuizQuestion.Prompt}" Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <Button Content="{Binding CurrentQuizQuestion.Choices[0], StringFormat=A   {0}}" Style="{StaticResource OutlineButton}" Background="{Binding CurrentQuizQuestion.ChoiceABackground}" BorderBrush="{Binding CurrentQuizQuestion.ChoiceABorder}" IsHitTestVisible="{Binding CurrentQuizQuestion.CanSelectAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding SelectQuizAnswerCommand}" CommandParameter="0" />
            <Button Content="{Binding CurrentQuizQuestion.Choices[1], StringFormat=B   {0}}" Style="{StaticResource OutlineButton}" Background="{Binding CurrentQuizQuestion.ChoiceBBackground}" BorderBrush="{Binding CurrentQuizQuestion.ChoiceBBorder}" IsHitTestVisible="{Binding CurrentQuizQuestion.CanSelectAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding SelectQuizAnswerCommand}" CommandParameter="1" />
            <Button Content="{Binding CurrentQuizQuestion.Choices[2], StringFormat=C   {0}}" Style="{StaticResource OutlineButton}" Background="{Binding CurrentQuizQuestion.ChoiceCBackground}" BorderBrush="{Binding CurrentQuizQuestion.ChoiceCBorder}" IsHitTestVisible="{Binding CurrentQuizQuestion.CanSelectAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,10" Command="{Binding SelectQuizAnswerCommand}" CommandParameter="2" />
            <Button Content="{Binding CurrentQuizQuestion.Choices[3], StringFormat=D   {0}}" Style="{StaticResource OutlineButton}" Background="{Binding CurrentQuizQuestion.ChoiceDBackground}" BorderBrush="{Binding CurrentQuizQuestion.ChoiceDBorder}" IsHitTestVisible="{Binding CurrentQuizQuestion.CanSelectAnswer}" HorizontalContentAlignment="Left" Margin="0,0,0,18" Command="{Binding SelectQuizAnswerCommand}" CommandParameter="3" />

            <UniformGrid Columns="2">
                <Button Content="&lt;" Style="{StaticResource OutlineButton}" FontSize="20" Margin="0,0,6,0" Command="{Binding PreviousQuizCommand}" />
                <Button Content="&gt;" Style="{StaticResource OutlineButton}" FontSize="20" Margin="6,0,0,0" Command="{Binding NextQuizCommand}" />
            </UniformGrid>
        </StackPanel>

        <Border Visibility="{Binding IsIncompleteQuizSubmitDialogOpen, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource Card}" Padding="18" Width="340" MaxWidth="340" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Chưa làm đủ câu" Style="{StaticResource SectionTitleText}" TextAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding IncompleteQuizSubmitText}" Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,16" />
                    <UniformGrid Columns="2">
                        <Button Content="Quay lại" Style="{StaticResource OutlineButton}" Margin="0,0,6,0" Command="{Binding ContinueQuizCommand}" />
                        <Button Content="Nộp" Style="{StaticResource PrimaryButton}" Foreground="#111322" Margin="6,0,0,0" Command="{Binding ForceSubmitQuizCommand}" />
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
