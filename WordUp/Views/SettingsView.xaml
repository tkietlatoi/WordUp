<UserControl x:Class="WordUp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="22,18,22,22">
        <Grid>
            <Button Content="Quay lại" Style="{StaticResource IconButton}" Width="70" FontSize="12" HorizontalAlignment="Left" Command="{Binding NavigateCommand}" CommandParameter="Account" />
            <TextBlock Text="Cài đặt" Style="{StaticResource PageTitleText}" FontSize="21" HorizontalAlignment="Center" />
        </Grid>
        <Border Style="{StaticResource Card}" Margin="0,22,0,14">
            <StackPanel>
                <TextBlock Text="Âm thanh" FontWeight="Bold" />
                <Slider Value="{Binding AudioVolume, Mode=TwoWay}" Minimum="0" Maximum="100" Margin="0,18,0,0" />
            </StackPanel>
        </Border>
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Hệ thống" FontWeight="Bold" Margin="0,0,0,16" />
                <CheckBox Content="Nhắc học hằng ngày" IsChecked="{Binding DailyReminders, Mode=TwoWay}" Margin="0,0,0,16" />
                <CheckBox Content="Tự động phát âm thanh" IsChecked="{Binding AutoPlayAudio, Mode=TwoWay}" Margin="0,0,0,16" />
                <CheckBox Content="Chế độ ngoại tuyến" IsChecked="{Binding OfflineMode, Mode=TwoWay}" Margin="0,0,0,16" />
                <TextBlock Text="{Binding SettingsMessage}" Style="{StaticResource MutedText}" Margin="0,0,0,12" />
                <Button Content="Lưu cài đặt" Style="{StaticResource PrimaryButton}" Command="{Binding SaveSettingsCommand}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
