<UserControl x:Class="WordUp.Views.ForgotPasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WordUp">
    <Grid Margin="22,18,22,22">
        <Border Style="{StaticResource Card}"
                Width="386"
                MinHeight="430"
                VerticalAlignment="Center"
                Padding="28">
            <StackPanel>
                <TextBlock Text="Qu&#234;n m&#7853;t kh&#7849;u"
                           Style="{StaticResource PageTitleText}"
                           TextAlignment="Center" />
                <TextBlock Text="Nh&#7853;p email ho&#7863;c s&#7889; &#273;i&#7879;n tho&#7841;i &#273;&#227; li&#234;n k&#7871;t v&#7899;i t&#224;i kho&#7843;n &#273;&#7875; &#273;&#7863;t l&#7841;i m&#7853;t kh&#7849;u."
                           Style="{StaticResource MutedText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="300"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,24" />

                <TextBlock Text="Email ho&#7863;c s&#7889; &#273;i&#7879;n tho&#7841;i" Margin="0,0,0,6" />
                <TextBox Style="{StaticResource TextInput}"
                         Text="{Binding ForgotPasswordEmail, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <StackPanel Visibility="{Binding IsForgotPasswordVerified, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="M&#7853;t kh&#7849;u m&#7899;i" Margin="0,0,0,6" />
                    <PasswordBox Style="{StaticResource PasswordInput}"
                                 local:PasswordBoxHelper.BoundPassword="{Binding ForgotPasswordNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,4" />
                    <TextBlock Text="T&#7889;i thi&#7875;u 8 k&#253; t&#7921;" Style="{StaticResource MutedText}" FontSize="11" Margin="0,0,0,10" />
                    <TextBlock Text="X&#225;c nh&#7853;n m&#7853;t kh&#7849;u" Margin="0,0,0,6" />
                    <PasswordBox Style="{StaticResource PasswordInput}"
                                 local:PasswordBoxHelper.BoundPassword="{Binding ForgotPasswordConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12" />
                </StackPanel>

                <TextBlock Text="{Binding AuthMessage}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAuthMessageSuccess}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button Content="{Binding ForgotPasswordActionText}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ForgotPasswordCommand}" />
                <Button Content="Quay l&#7841;i &#273;&#259;ng nh&#7853;p"
                        Style="{StaticResource TextLinkButton}"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Login" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
