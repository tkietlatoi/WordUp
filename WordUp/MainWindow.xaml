<Window x:Class="WordUp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WordUp.Views"
        Title="WordUp"
        Width="430"
        Height="760"
        MinWidth="390"
        MinHeight="640"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Width" Value="104" />
            <Setter Property="Height" Value="66" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#111322" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="Transparent"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <StackPanel HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                                <Border x:Name="Indicator"
                                        Width="46"
                                        Height="3"
                                        Margin="0,5,0,0"
                                        Background="{StaticResource IndigoBrush}"
                                        CornerRadius="2"
                                        Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource IndigoBrush}" />
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource IndigoBrush}" />
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
            <Grid MaxWidth="520" HorizontalAlignment="Center">
                <views:LoginView Visibility="{Binding IsLoginView, Converter={StaticResource BoolToVisibility}}" />
                <views:RegisterView Visibility="{Binding IsRegisterView, Converter={StaticResource BoolToVisibility}}" />
                <views:ForgotPasswordView Visibility="{Binding IsForgotPasswordView, Converter={StaticResource BoolToVisibility}}" />
                <views:DashboardView Visibility="{Binding IsDashboardView, Converter={StaticResource BoolToVisibility}}" />
                <views:StudyView Visibility="{Binding IsStudyView, Converter={StaticResource BoolToVisibility}}" />
                <views:QuizView Visibility="{Binding IsQuizView, Converter={StaticResource BoolToVisibility}}" />
                <views:QuizResultView Visibility="{Binding IsQuizResultView, Converter={StaticResource BoolToVisibility}}" />
                <views:WordManagerView Visibility="{Binding IsWordManagerView, Converter={StaticResource BoolToVisibility}}" />
                <views:AnalyticsView Visibility="{Binding IsAnalyticsView, Converter={StaticResource BoolToVisibility}}" />
                <views:AccountView Visibility="{Binding IsAccountView, Converter={StaticResource BoolToVisibility}}" />
                <views:SettingsView Visibility="{Binding IsSettingsView, Converter={StaticResource BoolToVisibility}}" />
                <views:ProfileView Visibility="{Binding IsProfileView, Converter={StaticResource BoolToVisibility}}" />
                <views:AboutView Visibility="{Binding IsAboutView, Converter={StaticResource BoolToVisibility}}" />
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Visibility="{Binding ShowBottomNavigation, Converter={StaticResource BoolToVisibility}}">
            <UniformGrid Columns="4" MaxWidth="520" HorizontalAlignment="Center">
                <Button Content="Trang chủ" Style="{StaticResource NavButton}" Tag="{Binding IsDashboardView}" Command="{Binding SelectTabCommand}" CommandParameter="Dashboard" />
                <Button Content="Bài học" Style="{StaticResource NavButton}" Tag="{Binding IsStudyView}" Command="{Binding SelectTabCommand}" CommandParameter="Study" />
                <Button Content="Luyện tập" Style="{StaticResource NavButton}" Tag="{Binding IsQuizView}" Command="{Binding SelectTabCommand}" CommandParameter="Quiz" />
                <Button Content="Cá nhân" Style="{StaticResource NavButton}" Tag="{Binding IsAccountView}" Command="{Binding SelectTabCommand}" CommandParameter="Account" />
            </UniformGrid>
        </Border>
    </Grid>
</Window>
